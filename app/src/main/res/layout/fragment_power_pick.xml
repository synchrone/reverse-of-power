<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.game.remoteclient.ui.SunburstBackgroundView
        android:id="@+id/sunburstBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Initial state: category name + tappable pentagon -->
    <LinearLayout
        android:id="@+id/pickContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CATEGORY SELECTED"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:shadowColor="#80000000"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="3"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/categoryNameText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:shadowColor="#80000000"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="3"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            tools:text="The World Today" />

        <!-- Pentagon icon -->
        <View
            android:id="@+id/pentagonIcon"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:background="@drawable/pentagon_background" />

        <TextView
            android:id="@+id/powerPickLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="POWER PICK"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#D4AF37"
            android:shadowColor="#80000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="2"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/descriptionText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Play a Power Pick once per game\nto overrule everyone else's choice"
            android:textSize="14sp"
            android:textColor="#CCFFFFFF"
            android:gravity="center"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="16dp" />

    </LinearLayout>

    <!-- Accepted state -->
    <LinearLayout
        android:id="@+id/acceptedContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:id="@+id/acceptedTitleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CATEGORY SELECTED"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:shadowColor="#80000000"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="3" />

        <TextView
            android:id="@+id/acceptedCategoryText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:shadowColor="#80000000"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="3"
            android:layout_marginTop="8dp"
            tools:text="Who's This?" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Power Pick accepted!"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:shadowColor="#80000000"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="3"
            android:layout_marginTop="24dp" />

    </LinearLayout>

</FrameLayout>
