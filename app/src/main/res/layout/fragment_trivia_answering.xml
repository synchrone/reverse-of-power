<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.game.remoteclient.ui.SunburstBackgroundView
        android:id="@+id/sunburstBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="16dp">

        <TextView
            android:id="@+id/questionText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:shadowColor="#80000000"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="3"
            android:gravity="center"
            android:layout_marginBottom="24dp"
            tools:text="Everyone wanted a pair in the 00s. What are they?" />

        <!-- 2x2 answer grid -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <!-- Top row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center">

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_margin="8dp">

                    <Button
                        android:id="@+id/answer0"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:textSize="34sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/white"
                        android:backgroundTint="#CC444444"
                        android:paddingHorizontal="58dp"
                        tools:text="EGGOs" />

                    <com.game.remoteclient.ui.NibblersOverlayView
                        android:id="@+id/nibblersOverlay0"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:translationZ="7dp"
                        android:visibility="gone" />

                    <com.game.remoteclient.ui.IceOverlayView
                        android:id="@+id/iceOverlay0"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:translationZ="8dp"
                        android:visibility="gone" />

                    <com.game.remoteclient.ui.GloopOverlayView
                        android:id="@+id/gloopOverlay0"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:translationZ="9dp"
                        android:visibility="gone" />
                </FrameLayout>

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_margin="8dp">

                    <Button
                        android:id="@+id/answer1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:textSize="34sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/white"
                        android:backgroundTint="#CC444444"
                        android:paddingHorizontal="58dp"
                        tools:text="UGGs" />

                    <com.game.remoteclient.ui.NibblersOverlayView
                        android:id="@+id/nibblersOverlay1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:translationZ="7dp"
                        android:visibility="gone" />

                    <com.game.remoteclient.ui.IceOverlayView
                        android:id="@+id/iceOverlay1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:translationZ="8dp"
                        android:visibility="gone" />

                    <com.game.remoteclient.ui.GloopOverlayView
                        android:id="@+id/gloopOverlay1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:translationZ="9dp"
                        android:visibility="gone" />
                </FrameLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/finalsWarning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Finals! Wrong answers are rejected!"
                android:textSize="14sp"
                android:textStyle="bold|italic"
                android:textColor="#FFDDDD"
                android:gravity="center"
                android:paddingVertical="4dp"
                android:visibility="gone" />

            <!-- Bottom row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center">

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_margin="8dp">

                    <Button
                        android:id="@+id/answer2"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:textSize="34sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/white"
                        android:backgroundTint="#CC444444"
                        android:paddingHorizontal="58dp"
                        tools:text="OWLs" />

                    <com.game.remoteclient.ui.NibblersOverlayView
                        android:id="@+id/nibblersOverlay2"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:translationZ="7dp"
                        android:visibility="gone" />

                    <com.game.remoteclient.ui.IceOverlayView
                        android:id="@+id/iceOverlay2"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:translationZ="8dp"
                        android:visibility="gone" />

                    <com.game.remoteclient.ui.GloopOverlayView
                        android:id="@+id/gloopOverlay2"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:translationZ="9dp"
                        android:visibility="gone" />
                </FrameLayout>

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_margin="8dp">

                    <Button
                        android:id="@+id/answer3"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:textSize="34sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/white"
                        android:backgroundTint="#CC444444"
                        android:paddingHorizontal="58dp"
                        tools:text="ARGHs" />

                    <com.game.remoteclient.ui.NibblersOverlayView
                        android:id="@+id/nibblersOverlay3"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:translationZ="7dp"
                        android:visibility="gone" />

                    <com.game.remoteclient.ui.IceOverlayView
                        android:id="@+id/iceOverlay3"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:translationZ="8dp"
                        android:visibility="gone" />

                    <com.game.remoteclient.ui.GloopOverlayView
                        android:id="@+id/gloopOverlay3"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:translationZ="9dp"
                        android:visibility="gone" />
                </FrameLayout>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Full-screen touch interceptor for gloop wiping (allows starting swipe from anywhere) -->
    <View
        android:id="@+id/gloopTouchInterceptor"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:translationZ="9.5dp"
        android:visibility="gone" />

    <com.game.remoteclient.ui.BomblesOverlayView
        android:id="@+id/bomblesOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:translationZ="10dp"
        android:visibility="gone" />

    <View
        android:id="@+id/wrongAnswerOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:translationZ="12dp"
        android:background="#66CC0000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone" />

    <FrameLayout
        android:id="@+id/bomblesExplosionOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:translationZ="14dp"
        android:background="#BBFFFFFF"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Don\u0027t touch the bombles!"
            android:textSize="42sp"
            android:textStyle="bold"
            android:textColor="#333333" />
    </FrameLayout>

</FrameLayout>
