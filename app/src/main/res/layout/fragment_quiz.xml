<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Question Text at the top -->
    <TextView
        android:id="@+id/questionText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/question_placeholder"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:gravity="center"
        android:padding="16dp"
        android:background="@color/surface"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="What is the capital of France?" />

    <!-- Timer -->
    <TextView
        android:id="@+id/timerText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="30"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/accent"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/questionText"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="8dp"
        tools:text="30" />

    <!-- Answer Buttons Grid -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/answersContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/timerText"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Top Left - Answer A (Green) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/answerAButton"
            style="@style/QuizButton"
            android:text="A"
            android:backgroundTint="@color/answer_a"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/answerCButton"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/answerBButton"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintVertical_weight="1"
            tools:text="Answer A" />

        <!-- Top Right - Answer B (Red) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/answerBButton"
            style="@style/QuizButton"
            android:text="B"
            android:backgroundTint="@color/answer_b"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/answerDButton"
            app:layout_constraintStart_toEndOf="@id/answerAButton"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintVertical_weight="1"
            tools:text="Answer B" />

        <!-- Bottom Left - Answer C (Yellow) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/answerCButton"
            style="@style/QuizButton"
            android:text="C"
            android:backgroundTint="@color/answer_c"
            android:textColor="@color/black"
            app:layout_constraintTop_toBottomOf="@id/answerAButton"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/answerDButton"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintVertical_weight="1"
            tools:text="Answer C" />

        <!-- Bottom Right - Answer D (Blue) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/answerDButton"
            style="@style/QuizButton"
            android:text="D"
            android:backgroundTint="@color/answer_d"
            app:layout_constraintTop_toBottomOf="@id/answerBButton"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/answerCButton"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintVertical_weight="1"
            tools:text="Answer D" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Overlay for when answer is submitted -->
    <View
        android:id="@+id/answerOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#CC000000"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/answerSubmittedText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Answer Submitted!"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
