<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.game.remoteclient.ui.SunburstBackgroundView
        android:id="@+id/sunburstBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <com.game.remoteclient.ui.WhirlpoolView
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Counter -->
    <TextView
        android:id="@+id/counterText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:shadowColor="#80000000"
        android:shadowDx="2"
        android:shadowDy="2"
        android:shadowRadius="3"
        android:background="#40000000"
        android:paddingHorizontal="16dp"
        android:paddingVertical="4dp"
        android:layout_marginTop="8dp"
        tools:text="14 to go" />

    <!-- Question text -->
    <TextView
        android:id="@+id/questionText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="56dp"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:shadowColor="#80000000"
        android:shadowDx="1"
        android:shadowDy="1"
        android:shadowRadius="2"
        android:gravity="center"
        android:paddingHorizontal="16dp"
        android:paddingVertical="4dp"
        tools:text="Complete the names of the comedy films" />

    <!-- Word tiles area -->
    <com.game.remoteclient.ui.FlowLayout
        android:id="@+id/wordTiles"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginBottom="40dp" />

    <!-- Letter choice buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginBottom="24dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="8dp">

        <TextView
            android:id="@+id/letter0"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginHorizontal="4dp"
            android:gravity="center"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:background="@drawable/circle_background"
            android:backgroundTint="#F0EAD6"
            android:clickable="true"
            android:focusable="true"
            tools:text="A" />

        <TextView
            android:id="@+id/letter1"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginHorizontal="4dp"
            android:gravity="center"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:background="@drawable/circle_background"
            android:backgroundTint="#F0EAD6"
            android:clickable="true"
            android:focusable="true"
            tools:text="E" />

        <TextView
            android:id="@+id/letter2"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginHorizontal="4dp"
            android:gravity="center"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:background="@drawable/circle_background"
            android:backgroundTint="#F0EAD6"
            android:clickable="true"
            android:focusable="true"
            tools:text="I" />

        <TextView
            android:id="@+id/letter3"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginHorizontal="4dp"
            android:gravity="center"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:background="@drawable/circle_background"
            android:backgroundTint="#F0EAD6"
            android:clickable="true"
            android:focusable="true"
            tools:text="O" />

        <TextView
            android:id="@+id/letter4"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginHorizontal="4dp"
            android:gravity="center"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:background="@drawable/circle_background"
            android:backgroundTint="#F0EAD6"
            android:clickable="true"
            android:focusable="true"
            tools:text="U" />
    </LinearLayout>

    <!-- Wrong answer overlay (red flash) -->
    <View
        android:id="@+id/wrongAnswerOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#60FF0000"
        android:visibility="gone" />

</FrameLayout>
