<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Debug Launcher"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp" />

        <!-- Trivia Configuration -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Trivia Configuration"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="12dp" />

        <!-- Power Plays -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Power Plays"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp" />

        <!-- Freeze -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <View
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="8dp"
                android:background="#4FC3F7" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Freeze"
                android:textSize="16sp"
                android:textColor="@color/text_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFreezeMinus"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="-"
                android:textSize="18sp"
                android:padding="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

            <TextView
                android:id="@+id/txtFreezeCount"
                android:layout_width="32dp"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:gravity="center" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFreezePlus"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="+"
                android:textSize="18sp"
                android:padding="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />
        </LinearLayout>

        <!-- Bombles -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <View
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="8dp"
                android:background="#FFD600" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Bombles"
                android:textSize="16sp"
                android:textColor="@color/text_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBomblesMinus"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="-"
                android:textSize="18sp"
                android:padding="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

            <TextView
                android:id="@+id/txtBomblesCount"
                android:layout_width="32dp"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:gravity="center" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBomblesPlus"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="+"
                android:textSize="18sp"
                android:padding="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />
        </LinearLayout>

        <!-- Nibblers -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <View
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="8dp"
                android:background="#FF7043" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Nibblers"
                android:textSize="16sp"
                android:textColor="@color/text_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNibblersMinus"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="-"
                android:textSize="18sp"
                android:padding="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

            <TextView
                android:id="@+id/txtNibblersCount"
                android:layout_width="32dp"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:gravity="center" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNibblersPlus"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="+"
                android:textSize="18sp"
                android:padding="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />
        </LinearLayout>

        <!-- Gloop -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <View
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="8dp"
                android:background="#66BB6A" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Gloop"
                android:textSize="16sp"
                android:textColor="@color/text_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGloopMinus"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="-"
                android:textSize="18sp"
                android:padding="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

            <TextView
                android:id="@+id/txtGloopCount"
                android:layout_width="32dp"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:gravity="center" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGloopPlus"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="+"
                android:textSize="18sp"
                android:padding="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />
        </LinearLayout>

        <!-- Finals Mode -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/chkFinals"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Finals mode (wrong answers rejected)"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="12dp" />

        <!-- Launch Trivia -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLaunchTrivia"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Launch Trivia"
            android:textSize="16sp"
            android:layout_marginBottom="24dp" />

        <!-- Linking Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Other Minigames"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLinking"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Linking - Match Pairs"
            android:backgroundTint="#E8679A"
            android:layout_marginBottom="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSorting"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sorting - Sort Into Buckets"
            android:backgroundTint="#E8679A"
            android:layout_marginBottom="32dp" />

    </LinearLayout>
</ScrollView>
