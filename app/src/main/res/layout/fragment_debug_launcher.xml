<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Debug Launcher"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp" />

        <!-- Trivia Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Trivia Answering"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTriviaNoEffect"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Trivia - No Power Play"
            android:layout_marginBottom="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTriviaFreeze"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Trivia - Freeze (Ice)"
            android:backgroundTint="#4FC3F7"
            android:layout_marginBottom="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTriviaFreezeDouble"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Trivia - Freeze x2 (Thick Ice)"
            android:backgroundTint="#29B6F6"
            android:layout_marginBottom="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTriviaBombles"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Trivia - Bombles"
            android:backgroundTint="#FFD600"
            android:textColor="#000000"
            android:layout_marginBottom="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTriviaBombles2x"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Trivia - Bombles x2 (stacked)"
            android:backgroundTint="#F9A825"
            android:textColor="#000000"
            android:layout_marginBottom="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTriviaNibblers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Trivia - Nibblers"
            android:backgroundTint="#FF7043"
            android:layout_marginBottom="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTriviaGloop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Trivia - Gloop"
            android:backgroundTint="#66BB6A"
            android:layout_marginBottom="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTriviaDoubleTrouble"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Trivia - Double Trouble (Freeze+Bombles)"
            android:backgroundTint="#9C27B0"
            android:layout_marginBottom="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTriviaFinals"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Trivia - Finals (wrong answers rejected)"
            android:backgroundTint="#F44336"
            android:layout_marginBottom="16dp" />

        <!-- Linking Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Linking Answers"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLinking"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Linking - Match Pairs"
            android:backgroundTint="#E8679A"
            android:layout_marginBottom="16dp" />

        <!-- Sorting Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sorting Answers"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSorting"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sorting - Sort Into Buckets"
            android:backgroundTint="#E8679A"
            android:layout_marginBottom="32dp" />

    </LinearLayout>
</ScrollView>
