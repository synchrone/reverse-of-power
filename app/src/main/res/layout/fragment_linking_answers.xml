<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.game.remoteclient.ui.SunburstBackgroundView
        android:id="@+id/sunburstBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <com.game.remoteclient.ui.WhirlpoolView
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Timer -->
    <TextView
        android:id="@+id/timerText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:shadowColor="#80000000"
        android:shadowDx="2"
        android:shadowDy="2"
        android:shadowRadius="3"
        android:background="#40000000"
        android:paddingHorizontal="16dp"
        android:paddingVertical="4dp"
        android:layout_marginTop="8dp"
        tools:text="15 to go" />

    <!-- Top-left half-circle (Direction=1) -->
    <FrameLayout
        android:id="@+id/topSlot0"
        android:layout_width="200dp"
        android:layout_height="100dp"
        android:layout_gravity="start|top"
        android:layout_marginStart="20dp"
        android:layout_marginTop="24dp"
        android:rotation="-12">

        <TextView
            android:id="@+id/topText0"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:background="@drawable/half_circle_top"
            android:backgroundTint="#F0EAD6"
            android:padding="8dp"
            tools:text="James Bond" />
    </FrameLayout>

    <!-- Top-right half-circle (Direction=1) -->
    <FrameLayout
        android:id="@+id/topSlot1"
        android:layout_width="200dp"
        android:layout_height="100dp"
        android:layout_gravity="end|top"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="16dp"
        android:rotation="12">

        <TextView
            android:id="@+id/topText1"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:background="@drawable/half_circle_top"
            android:backgroundTint="#F0EAD6"
            android:padding="8dp"
            tools:text="Sarah Connor" />
    </FrameLayout>

    <!-- Top-center half-circle (Direction=1) -->
    <FrameLayout
        android:id="@+id/topSlot2"
        android:layout_width="200dp"
        android:layout_height="100dp"
        android:layout_gravity="center_horizontal|top"
        android:layout_marginTop="20dp"
        android:rotation="3"
        android:visibility="invisible">

        <TextView
            android:id="@+id/topText2"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:background="@drawable/half_circle_top"
            android:backgroundTint="#F0EAD6"
            android:padding="8dp"
            tools:text="Batman" />
    </FrameLayout>

    <!-- Instruction text -->
    <TextView
        android:id="@+id/instructionText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="Drag to link answers"
        android:textSize="16sp"
        android:textColor="#CCFFFFFF"
        android:background="#30000000"
        android:paddingHorizontal="20dp"
        android:paddingVertical="6dp" />

    <!-- Bottom-left half-circle (Direction=2) -->
    <FrameLayout
        android:id="@+id/bottomSlot0"
        android:layout_width="200dp"
        android:layout_height="100dp"
        android:layout_gravity="start|bottom"
        android:layout_marginStart="60dp"
        android:layout_marginBottom="24dp"
        android:rotation="8">

        <TextView
            android:id="@+id/bottomText0"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:background="@drawable/half_circle_bottom"
            android:backgroundTint="#F0EAD6"
            android:padding="8dp"
            tools:text="The Joker" />
    </FrameLayout>

    <!-- Bottom-right half-circle (Direction=2) -->
    <FrameLayout
        android:id="@+id/bottomSlot1"
        android:layout_width="200dp"
        android:layout_height="100dp"
        android:layout_gravity="end|bottom"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="16dp"
        android:rotation="-8">

        <TextView
            android:id="@+id/bottomText1"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:background="@drawable/half_circle_bottom"
            android:backgroundTint="#F0EAD6"
            android:padding="8dp"
            tools:text="Dr. No" />
    </FrameLayout>

    <!-- Bottom-center half-circle (Direction=2) -->
    <FrameLayout
        android:id="@+id/bottomSlot2"
        android:layout_width="200dp"
        android:layout_height="100dp"
        android:layout_gravity="center_horizontal|bottom"
        android:layout_marginBottom="20dp"
        android:rotation="-3"
        android:visibility="invisible">

        <TextView
            android:id="@+id/bottomText2"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:background="@drawable/half_circle_bottom"
            android:backgroundTint="#F0EAD6"
            android:padding="8dp"
            tools:text="Lex Luthor" />
    </FrameLayout>

    <!-- Feedback overlay -->
    <FrameLayout
        android:id="@+id/feedbackOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/circle_background"
            android:backgroundTint="#DDFFFFFF"
            android:padding="32dp">

            <TextView
                android:id="@+id/feedbackTopText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:gravity="center"
                tools:text="Superman" />

            <TextView
                android:id="@+id/feedbackBottomText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:gravity="center"
                android:layout_marginTop="8dp"
                tools:text="Lex Luthor" />

        </LinearLayout>

    </FrameLayout>

    <!-- Drag line overlay -->
    <com.game.remoteclient.ui.LinkingLineView
        android:id="@+id/linkingLine"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</FrameLayout>
