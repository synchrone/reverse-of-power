<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.game.remoteclient.ui.SunburstBackgroundView
        android:id="@+id/sunburstBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <com.game.remoteclient.ui.WhirlpoolView
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Counter -->
    <TextView
        android:id="@+id/counterText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:shadowColor="#80000000"
        android:shadowDx="2"
        android:shadowDy="2"
        android:shadowRadius="3"
        android:background="#40000000"
        android:paddingHorizontal="16dp"
        android:paddingVertical="4dp"
        android:layout_marginTop="8dp"
        tools:text="15 to go" />

    <!-- Question text -->
    <TextView
        android:id="@+id/questionText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="40dp"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:shadowColor="#80000000"
        android:shadowDx="1"
        android:shadowDy="1"
        android:shadowRadius="2"
        android:paddingHorizontal="16dp"
        android:paddingVertical="4dp"
        tools:text="Smash the movie that ISN'T science fiction" />

    <!-- 3 answer buttons in a row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="16dp">

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center">

            <TextView
                android:id="@+id/answer0"
                android:layout_width="110dp"
                android:layout_height="110dp"
                android:layout_gravity="center"
                android:gravity="center"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:background="@drawable/circle_background"
                android:backgroundTint="#F0EAD6"
                android:padding="12dp"
                android:clickable="true"
                android:focusable="true"
                tools:text="Moon" />
        </FrameLayout>

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center">

            <TextView
                android:id="@+id/answer1"
                android:layout_width="110dp"
                android:layout_height="110dp"
                android:layout_gravity="center"
                android:gravity="center"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:background="@drawable/circle_background"
                android:backgroundTint="#F0EAD6"
                android:padding="12dp"
                android:clickable="true"
                android:focusable="true"
                tools:text="Jurassic Park" />
        </FrameLayout>

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center">

            <TextView
                android:id="@+id/answer2"
                android:layout_width="110dp"
                android:layout_height="110dp"
                android:layout_gravity="center"
                android:gravity="center"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:background="@drawable/circle_background"
                android:backgroundTint="#F0EAD6"
                android:padding="12dp"
                android:clickable="true"
                android:focusable="true"
                tools:text="Dumb &amp; Dumber" />
        </FrameLayout>
    </LinearLayout>

    <!-- Instruction text -->
    <TextView
        android:id="@+id/instructionText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="24dp"
        android:textSize="16sp"
        android:textColor="@android:color/white"
        android:background="#60000000"
        android:paddingHorizontal="20dp"
        android:paddingVertical="8dp"
        android:text="Tap to smash odd one out" />

    <!-- Wrong answer overlay (red flash) -->
    <View
        android:id="@+id/wrongAnswerOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#60FF0000"
        android:visibility="gone" />

</FrameLayout>
