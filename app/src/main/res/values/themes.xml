<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.GameRemoteClient" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <item name="materialButtonStyle">@style/Widget.App.Button</item>
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.App.Rounded</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.App.Rounded</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.App.Rounded</item>
        <item name="shapeAppearanceCornerExtraLarge">@style/ShapeAppearance.App.Rounded</item>
        <item name="shapeAppearanceCornerLarge">@style/ShapeAppearance.App.Rounded</item>
        <item name="shapeAppearanceCornerMedium">@style/ShapeAppearance.App.Rounded</item>
        <item name="shapeAppearanceCornerSmall">@style/ShapeAppearance.App.Rounded</item>
        <item name="shapeAppearanceCornerExtraSmall">@style/ShapeAppearance.App.Rounded</item>
    </style>

    <style name="ShapeAppearance.App.Rounded" parent="">
        <item name="cornerSize">8dp</item>
        <item name="cornerFamily">rounded</item>
    </style>

    <style name="Widget.App.Button" parent="Widget.Material3.Button">
        <item name="shapeAppearance">@style/ShapeAppearance.App.Rounded</item>
    </style>

    <style name="QuizButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
        <item name="android:elevation">4dp</item>
    </style>
</resources>
